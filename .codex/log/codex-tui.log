able\n\nfrom fastapi import HTTPException, Request, Response\n\n\nasync def require_role(request: Request, call_next: Callable[[Request], Response]) -> Response:\n    if request.url.path.startswith(\"/api/admin\") and request.headers.get(\"x-role\") != \"admin\":\n        raise HTTPException(status_code=403, detail=\"forbidden\")\n    return await call_next(request)\nEOF\n\ncat > src/services/auth_service.py << 'EOF'\ndef authenticate_user(email: str, password: str) -> bool:\n    return bool(email and password)\nEOF\n\ncat > src/services/audit_log.py << 'EOF'\ndef record_event(action: str, actor: str = \"system\", details: dict | None = None) -> dict:\n    return {\"action\": action, \"actor\": actor, \"details\": details or {}}\nEOF\n\ncat > src/services/storage_client.py << 'EOF'\ndef store_file(storage_key: str, payload: bytes) -> dict:\n    return {\"storage_key\": storage_key, \"size_bytes\": len(payload)}\nEOF\n\ncat > src/services/notification_service.py << 'EOF'\ndef send_email(recipient: str, subject: str, body: str) -> dict:\n    return {\"recipient\": recipient, \"sent\": bool(recipient and subject and body)}\nEOF\n\ncat > src/services/payment_client.py << 'EOF'\ndef process_payment(registration_id: str, amount: float, currency: str = \"USD\") -> dict:\n    return {\n        \"registration_id\": registration_id,\n        \"amount\": amount,\n        \"currency\": currency,\n        \"status\": \"paid\" if amount >= 0 else \"declined\",\n    }\nEOF\n\ncat > src/services/scheduling_engine.py << 'EOF'\ndef generate_schedule() -> dict:\n    return {\"status\": \"generated\"}\nEOF\n\ncat > alembic.ini << 'EOF'\n[alembic]\nscript_location = migrations\nsqlalchemy.url = sqlite:///./cms.db\nEOF\n\ncat > migrations/env.py << 'EOF'\n\"\"\"Alembic environment placeholder for local migrations.\"\"\"\nEOF\n\ncat > specs/001-uc-spec-union/uat/uat-index.md << 'EOF'\n# Unified UAT Index\n\nThis index consolidates UAT scenarios from TC-XX files mapped to UC-XX stories.\nEOF\n\ncat > src/web/app.py << 'EOF'\nfrom fastapi import FastAPI\n\nfrom src.web.routes import router as web_router\n\napp = FastAPI(title=\"CMS Web\")\napp.include_router(web_router)\nEOF\n"} thread_id=019cbb97-579e-78b3-b247-eee325847288
