),\n        manuscript_format=str(data.get(\"manuscript_format\", \"\")),\n    )\n    return {\"service\": \"submission_create_service\", \"submission\": submission}\n\n\ndef reset_submission_create_state() -> None:\n    _submissions.clear()\nEOF"} thread_id=019cbb97-579e-78b3-b247-eee325847288
