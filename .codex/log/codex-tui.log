+        "http_version": "1.1",
+        "method": "GET",
+        "path": path,
+        "raw_path": path.encode(),
+        "query_string": b"",
+        "headers": headers or [],
+        "client": ("test", 123),
+        "server": ("testserver", 80),
+        "scheme": "http",
+    }
+    return Request(scope)
