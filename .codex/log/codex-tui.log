+from fastapi.routing import APIRoute
+from fastapi.testclient import TestClient
+
+from src.web.app import app
+
+
+def test_web_get_routes_smoke() -> None:
+    client = TestClient(app)
+    get_paths: list[str] = []
+    for route in app.routes:
+        if not isinstance(route, APIRoute):
+            continue
+        if "GET" not in route.methods:
+            continue
+        if "{" in route.path:
+            continue
+        get_paths.append(route.path)
+
+    # Keep deterministic order to make failures reproducible.
+    for path in sorted(set(get_paths)):
+        response = client.get(path)
+        assert response.status_code < 500, f"GET {path} returned {response.status_code}"
*** End Patch
