${p}\" >> \"$f\"\n    done\n    cat >> \"$f\" <<'PY'\n    return execute(data)\nPY\n  fi\ndone\n\nfor f in src/web/*.py; do\n  [[ \"$f\" =~ (app.py|routes.py) ]] && continue\n  if ! rg -q 'return \\{\"page\": ' \"$f\"; then\n    continue\n  fi\n  base=$(basename \"$f\" .py)\n  service=\"${base}_service\"\n  route=$(sed -n 's/@router\\.get(\"\\(.*\\)\").*/\\1/p' \"$f\" | head -n1)\n  func=$(sed -n 's/def \\([a-zA-Z0-9_]*\\)(.*/\\1/p' \"$f\" | head -n1)\n\n  cat > \"$f\" <<PY\nfrom fastapi import APIRouter\n\nfrom src.services.${service} import execute\n\nrouter = APIRouter(tags=[\"web-${base}\"])\n\n\n@router.get(\"${route}\")\ndef ${func}() -> dict:\n    return {\"page\": \"${base}\", \"data\": execute({})}\nPY\ndone\nEOF\nbash /tmp/refresh_stub_handlers.sh"} thread_id=019cbb97-579e-78b3-b247-eee325847288
