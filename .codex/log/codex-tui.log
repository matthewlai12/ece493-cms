_id}/publish\" ;;\n    review_invite_notify) echo \"/referee/invitations\" ;;\n    review_invite_response) echo \"/referee/invitations/{invitation_id}/response\" ;;\n    assigned_papers) echo \"/referee/assignments\" ;;\n    review_submit) echo \"/reviews\" ;;\n    referee_assign) echo \"/referees/assignments\" ;;\n    referee_workload|three_referees) echo \"/referees/assignments/validate\" ;;\n    conference_register) echo \"/registrations\" ;;\n    registration_payment) echo \"/registrations/{registration_id}/payment\" ;;\n    payment_confirmation) echo \"/registrations/{registration_id}/confirmation\" ;;\n    schedule_view_attendee) echo \"/schedule/attendee\" ;;\n    registration_validation) echo \"/auth/register/validate\" ;;\n    *) echo \"/${1//_/-}\" ;;\n  esac\n}\n\n# Models\nfor f in $(rg -o \"src/models/[a-z_]+\\.py\" specs/001-uc-spec-union/tasks.md | sort -u); do\n  base=$(basename \"$f\" .py)\n  [[ \"$base\" == \"base\" ]] && continue\n  cls=$(model_class \"$base\")\n  cat > \"$f\" <<PY\nfrom sqlalchemy import Integer\nfrom sqlalchemy.orm import Mapped, mapped_column\n\nfrom src.models.base import Base\n\n\nclass $cls(Base):\n    __tablename__ = \"$base\"\n\n    id: Mapped[int] = mapped_column(Integer, primary_key=True, autoincrement=True)\nPY\ndone\n\n# Services\nfor f in $(rg -o \"src/services/[a-z_]+\\.py\" specs/001-uc-spec-union/tasks.md | sort -u); do\n  base=$(basename \"$f\" .py)\n  [[ \"$base\" == \"audit_log\" || \"$base\" == \"auth_service\" || \"$base\" == \"storage_client\" || \"$base\" == \"notification_service\" || \"$base\" == \"payment_client\" || \"$base\" == \"scheduling_engine\" ]] && continue\n  cat > \"$f\" <<PY\ndef execute(payload: dict | None = None) -> dict:\n    return {\"service\": \"$base\", \"ok\": True, \"payload\": payload or {}}\nPY\ndone\n\n# API handlers\nfor f in $(rg -o \"src/api/[a-z_]+\\.py\" specs/001-uc-spec-union/tasks.md | sort -u); do\n  base=$(basename \"$f\" .py)\n  [[ \"$base\" == \"app\" || \"$base\" == \"routes\" ]] && continue\n  method=$(api_method \"$base\")\n  path=$(api_path \"$base\")\n  cat > \"$f\" <<PY\nfrom fastapi import APIRouter\n\nrouter = APIRouter(tags=[\"$base\"])\n\n\n@router.$method(\"$path\")\ndef handle_$base() -> dict:\n    return {\"route\": \"$base\", \"ok\": True}\nPY\ndone\n\n# Web handlers\nfor f in $(rg -o \"src/web/[a-z_]+\\.py\" specs/001-uc-spec-union/tasks.md | sort -u); do\n  base=$(basename \"$f\" .py)\n  [[ \"$base\" == \"app\" || \"$base\" == \"routes\" ]] && continue\n  cat > \"$f\" <<PY\nfrom fastapi import APIRouter\n\nrouter = APIRouter(tags=[\"web-$base\"])\n\n\n@router.get(\"/$base\")\ndef page_$base() -> dict:\n    return {\"page\": \"$base\", \"ok\": True}\nPY\ndone\nEOF\nbash /tmp/gen_scaffold.sh"} thread_id=019cbb97-579e-78b3-b247-eee325847288
